<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/window_background_color"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_actionbar_for_selector" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bar_background_color"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/date_picker_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/shape_solid_f0_radius_4"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:textColor="@color/item_title_color"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/date_picker_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/shape_solid_f0_radius_4"
            android:gravity="start"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:textColor="@color/item_title_color"
            android:textSize="16sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <CalendarView
                android:id="@+id/picker_calendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@color/bar_background_color" />

            <TimePicker
                android:id="@+id/picker_time"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:background="@color/bar_background_color"
                android:timePickerMode="spinner" />

            <TextView
                android:id="@+id/clear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@color/bar_background_color"
                android:foreground="?selectableItemBackground"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:text="@string/clear"
                android:textColor="@color/item_title_color"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>