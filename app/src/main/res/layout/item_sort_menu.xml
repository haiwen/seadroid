<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/pop_item_padding_vertical">

    <ImageView
        android:id="@+id/menu_view_gallery_icon"
        android:layout_width="@dimen/pop_icon_width"
        android:layout_height="@dimen/pop_icon_height"
        android:layout_marginHorizontal="@dimen/pop_icon_margin_horizontal"
        android:clickable="false"
        android:padding="@dimen/pop_icon_padding"
        android:src="@drawable/popup_window_icon"
        app:tint="@color/material_grey_500" />

    <TextView
        android:id="@+id/menu_view_gallery_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="@integer/popup_window_title_max_lines"
        android:text="@string/menu_action_view_gallery"
        android:textColor="@color/item_title_color"
        android:textSize="@dimen/pop_title_text_size" />

</LinearLayout>